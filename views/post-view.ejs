<%- include("partials/header.ejs") %>
<div class="return-btn-div container">
  <form action="/return-home" method="get">
    <button>Return to homepage</button>
  </form>    
  
</div>
<div class="post-container">
  <h3 class="pb-4 mb-4 fst-italic border-bottom"><%= post.category %></h3>
  <article class="blog-post">
    <h2 class="display-5 link-body-emphasis mb-1"><%= post.title %></h2>
    <p class="blog-post-meta"><%= post.date %> by <%= post.author %></p>
    <hr />
    <p>
      <%= post.content %>
    </p>
    <div class="post-view-buttons">
        <form action="/post-update" method="get">
            <input type="hidden" name="id" value="<%= post.id %>">
            <button class="edit-btn" type="submit">Edit</button>
        </form>
        <form action="/delete-post" method="post">
                <input type="hidden" name="id" value="<%=post.id%>">
                <button class="delete-btn" type="submit">Delete</button>
        </form>
    </div>
</div>

<%- include("partials/footer.ejs") %>
